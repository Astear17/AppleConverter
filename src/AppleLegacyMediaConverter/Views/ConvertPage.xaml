<Page
    x:Class="AppleLegacyMediaConverter.Views.ConvertPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:AppleLegacyMediaConverter.Core.Models"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            AllowDrop="True"
            DragOver="DropZone_DragOver"
            Drop="DropZone_Drop"
            Padding="16"
            CornerRadius="8"
            BorderThickness="1"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Grid ColumnSpacing="16" RowSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.35*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1.25*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="Thả tệp Apple vào đây" Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Kéo thả tệp/thư mục hoặc chọn từ máy. Hỗ trợ iPhone, iPad, macOS, AirDrop và iCloud." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Click="AddFiles_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <SymbolIcon Symbol="Add" />
                                <TextBlock Text="Thêm tệp" />
                            </StackPanel>
                        </Button>
                        <Button Click="AddFolder_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <SymbolIcon Symbol="Folder" />
                                <TextBlock Text="Thêm thư mục" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Top">
                    <TextBlock Text="Hình ảnh" Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="HEIC/HEIF và ảnh thường" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <ComboBox
                        ItemsSource="{Binding ImageFormatOptions}"
                        SelectedItem="{Binding SelectedImageFormat, Mode=TwoWay}"
                        HorizontalAlignment="Stretch" />
                    <TextBlock Text="Live Photo" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <ComboBox
                        ItemsSource="{Binding LivePhotoActionOptions}"
                        SelectedItem="{Binding SelectedLivePhotoAction, Mode=TwoWay}"
                        HorizontalAlignment="Stretch" />
                </StackPanel>

                <StackPanel Grid.Column="2" Spacing="8" VerticalAlignment="Top">
                    <TextBlock Text="Video" Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <ComboBox
                        ItemsSource="{Binding VideoModeOptions}"
                        SelectedItem="{Binding SelectedVideoMode, Mode=TwoWay}"
                        HorizontalAlignment="Stretch" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <NumberBox
                            Width="112"
                            Minimum="1"
                            Maximum="3600"
                            SmallChange="1"
                            SpinButtonPlacementMode="Inline"
                            Value="{Binding FrameIntervalSeconds, Mode=TwoWay}" />
                        <TextBlock
                            Grid.Column="1"
                            Text="Khoảng cách khung: lấy 1 ảnh mỗi N giây. Chỉ dùng cho tách khung mỗi N giây."
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="3" Spacing="8" VerticalAlignment="Bottom">
                    <TextBlock Text="Nặng: MP4, tách nhiều khung, tách toàn bộ khung." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" MaxWidth="210" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Click="Convert_Click" IsEnabled="{Binding HasFiles}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <SymbolIcon Symbol="Play" />
                                <TextBlock Text="Chuyển đổi" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding CancelConversionCommand}" IsEnabled="{Binding IsConverting}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <SymbolIcon Symbol="Stop" />
                                <TextBlock Text="Hủy" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.35*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Padding="0"
                CornerRadius="8"
                BorderThickness="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid RowSpacing="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Padding="14" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Hàng đợi" Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <ComboBox
                            Grid.Column="1"
                            ItemsSource="{Binding FilterOptions}"
                            SelectedItem="{Binding SelectedFilter, Mode=TwoWay}"
                            HorizontalAlignment="Stretch" />
                        <Button Grid.Column="2" Command="{Binding RetryFailedCommand}" IsEnabled="{Binding HasFailures}" ToolTipService.ToolTip="Thử lại tệp lỗi">
                            <SymbolIcon Symbol="Refresh" />
                        </Button>
                        <Button Grid.Column="3" Command="{Binding ClearCompletedCommand}" IsEnabled="{Binding HasCompleted}" ToolTipService.ToolTip="Xóa tệp đã hoàn tất">
                            <SymbolIcon Symbol="Clear" />
                        </Button>
                        <Button Grid.Column="4" Command="{Binding ClearQueueCommand}" IsEnabled="{Binding HasFiles}" ToolTipService.ToolTip="Xóa hàng đợi">
                            <SymbolIcon Symbol="Delete" />
                        </Button>
                    </Grid>

                    <ListView Grid.Row="1" ItemsSource="{Binding FilteredQueue}" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="core:MediaFileItem">
                                <Grid Padding="12" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2.2*" />
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="3">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <Border
                                                Width="{Binding LivePhotoBadgeWidth}"
                                                Padding="6,2"
                                                CornerRadius="4"
                                                Background="{ThemeResource AccentFillColorSecondaryBrush}">
                                                <TextBlock Text="{Binding LivePhotoBadgeText}" FontSize="11" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding DisplayType}" TextWrapping="Wrap" />
                                    <TextBlock Grid.Column="2" Text="{Binding OutputTarget}" TextTrimming="CharacterEllipsis" />
                                    <StackPanel Grid.Column="3" Spacing="4">
                                        <TextBlock Text="{Binding StatusText}" />
                                        <ProgressBar Minimum="0" Maximum="100" Value="{Binding Progress}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                                        <Button Tag="{Binding}" Click="OpenSource_Click" ToolTipService.ToolTip="Mở thư mục nguồn">
                                            <SymbolIcon Symbol="OpenFile" />
                                        </Button>
                                        <Button Tag="{Binding}" Click="OpenOutput_Click" ToolTipService.ToolTip="Mở thư mục xuất">
                                            <SymbolIcon Symbol="OpenLocal" />
                                        </Button>
                                        <Button Tag="{Binding}" Click="CopyItemError_Click" ToolTipService.ToolTip="Sao chép lỗi">
                                            <SymbolIcon Symbol="Copy" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Grid Grid.Column="1" RowSpacing="14" VerticalAlignment="Top">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    Padding="18"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Đầu ra" Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <ComboBox
                            ItemsSource="{Binding OutputFolderModeOptions}"
                            SelectedItem="{Binding SelectedOutputFolderMode, Mode=TwoWay}"
                            HorizontalAlignment="Stretch" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding CustomOutputFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1" Click="SelectOutputFolder_Click">
                                <SymbolIcon Symbol="Folder" />
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="1"
                    Padding="18"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Tiến trình" Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <ProgressBar Minimum="0" Maximum="100" Value="{Binding TotalProgress}" />
                        <TextBlock Text="{Binding StatusText}" />
                        <TextBlock Text="{Binding EstimatedTimeText}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding SummaryText}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="2"
                    Padding="18"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Tóm tắt" Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="{Binding SummaryText}" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding SummaryDetailText}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding LastOutputFolder}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Click="OpenOutputFolder_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <SymbolIcon Symbol="OpenLocal" />
                                    <TextBlock Text="Mở thư mục xuất" />
                                </StackPanel>
                            </Button>
                            <Button Click="CopyFailedReport_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <SymbolIcon Symbol="Copy" />
                                    <TextBlock Text="Báo cáo lỗi" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
